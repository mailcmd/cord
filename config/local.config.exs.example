import Config

config :cord, :local_config, 
    websocket_manager: <module>,
    app_supervisor: <module>,
    events_pop_interval: 5_000,
    api_user_pass: "", # user:pass
    title: "SPI Down Detector",
    main_file: "main.html",
    favicon: "imgs/iso.ico",
    css_files: [
      "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css",
      "css/pico.css",
      "css/main.css"
    ],
    js_files: [
      "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js",
      "js/syslib.js",
      "js/main.js"
    ]

config :cord, :spi_down_detector,
    version: "0.1.0",
    token_expire: 600, # in seconds, default 3600 secs
    lat: -38.706895351298776,
    lng: -62.25236026480962,
    db: [
      hostname: "190.1.0.83",
      database: "spi40db",
      username: "spi40",
      password: "passspi40"
    ]

config :cord, :ftth_collector,
    start_delay: 5000,
    node_delay: 500,
    node_up_thresold: 0,
    threads: 12
